# celebratebanner-api · STAGING env template
#
# Identical KEYS to production, different VALUES. Stage exists so the prod
# launch isn't the first time the system runs end-to-end.
#
# Differences from production:
#   • All Stripe keys are sk_test_ / whsec_ from the test-mode webhook
#   • Public URLs point at staging.* hostnames
#   • Sentry environment label flips to "staging" so issues are filterable
#   • Sampling rate higher (1.0) — we want full traces in staging
#   • Recovery cap is low — don't email real customers from staging

NODE_ENV=production           # KEEP THIS — Node ecosystem assumes production-grade behavior
LOG_LEVEL=info
PUBLIC_SITE_URL=https://staging.celebratebanner.com
API_PUBLIC_URL=https://api.staging.celebratebanner.com

DATABASE_URL=postgres://app_user:STAGING_PASSWORD@HOST:5432/celebratebanner_staging?sslmode=require
PG_SSL=require
PG_POOL_SIZE=5

REDIS_URL=rediss://default:TOKEN@STAGING_HOST.upstash.io:6379

# Test-mode Stripe. The webhook endpoint in Stripe dashboard for staging
# should be a SEPARATE endpoint (its own whsec_) — never share with live.
STRIPE_SECRET_KEY=sk_test_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_STAGING_REPLACE

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA_STAGING_REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
S3_BUCKET=celebratebanner-uploads-staging
S3_CDN_BASE=https://cdn.staging.celebratebanner.com
S3_UPLOAD_TTL_SECONDS=600
S3_DOWNLOAD_TTL_SECONDS=86400        # 1 day — shorter than prod

DOWNLOAD_TOKEN_SECRET=DIFFERENT_FROM_PROD_32_BYTES
DOWNLOAD_TOKEN_TTL_DAYS=1
DOWNLOAD_TOKEN_MAX_USES=20

ADMIN_JWT_SECRET=DIFFERENT_FROM_PROD_32_BYTES
ADMIN_SESSION_TTL_HOURS=8
ADMIN_COOKIE_NAME=cb_admin
ADMIN_COOKIE_DOMAIN=.staging.celebratebanner.com

# Postmark sandbox / test mode — won't actually mail anyone but won't bounce either.
# Use the dedicated test API token from Postmark.
MAIL_FROM=CelebrateBanner Staging <info@celebratebanner.com>
POSTMARK_API_TOKEN=POSTMARK_TEST_TOKEN_REPLACE
POSTMARK_STREAM=outbound

RENDER_QUEUE_NAME=cb-renders-staging
RENDER_CONCURRENCY=1                  # one worker is enough for staging
RENDER_TIMEOUT_MS=300000
RENDER_ATTEMPTS=2

IMAGE_OPT_CONCURRENCY=2
IMAGE_OPT_DELAY_MS=8000

# Tightly cap recovery emails in staging — we never want to mass-email real
# users from a staging environment that happens to share a DB row.
RECOVERY_DELAY_HOURS=4
RECOVERY_INTERVAL_MS=3600000
RECOVERY_DAILY_CAP=5

SLIDESHOW_FPS=30
SLIDESHOW_BITRATE=4M
SLIDESHOW_DEFAULT_AUDIO_URL=

# Same Sentry project, different environment label so prod alerts aren't mixed.
SENTRY_DSN=https://PUBLIC_KEY@oXXXX.ingest.sentry.io/PROJECT
SENTRY_TRACES_SAMPLE_RATE=1.0
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/STAGING_WEBHOOK
ALERT_DEDUPE_TTL_SECONDS=60

BACKUP_S3_BUCKET=celebratebanner-backups-staging
BACKUP_RETENTION_DAYS=7
