# celebratebanner-api · LOCAL DEV env template
#
# For running the API on your laptop. Optimized for fast iteration:
#   • USE_MEMORY_PROJECT_STORE=1 skips Postgres entirely (no DB required)
#   • Stripe in test mode, webhook via `stripe listen --forward-to localhost:4000/...`
#   • S3 + Redis are required for the actual end-to-end flow; for UI work, you
#     can stub them out and use USE_MEMORY_PROJECT_STORE=1.

NODE_ENV=development
LOG_LEVEL=debug
PUBLIC_SITE_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# Local DB — Postgres in Docker or Homebrew, or leave unset and use memory store.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/celebratebanner_dev
PG_SSL=disable                          # SSL off for local Postgres
PG_POOL_SIZE=5

# Local Redis (Docker: `docker run -p 6379:6379 redis:7`)
# Comment out if not running BullMQ locally — render worker just won't pick up jobs.
REDIS_URL=redis://localhost:6379

# Stripe TEST keys ONLY in dev.
STRIPE_SECRET_KEY=sk_test_YOUR_TEST_KEY
# Run `stripe listen --forward-to localhost:4000/api/payments/webhook` and use
# the whsec_ the CLI prints (rotates each session — DO NOT commit yours).
STRIPE_WEBHOOK_SECRET=whsec_FROM_STRIPE_LISTEN

# S3 — point at a separate dev bucket so you don't pollute staging/prod
# OR run MinIO locally: docker run -p 9000:9000 minio/minio server /data
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin             # or your IAM dev keys
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=celebratebanner-dev
S3_CDN_BASE=http://localhost:9000/celebratebanner-dev

# Random throwaway secrets — DON'T paste production values here.
DOWNLOAD_TOKEN_SECRET=local-dev-only-not-secret
ADMIN_JWT_SECRET=local-dev-only-not-secret
ADMIN_COOKIE_NAME=cb_admin
# No COOKIE_DOMAIN — cookie scoped to localhost.

# Mailer — leave POSTMARK_API_TOKEN unset and mailer logs to console instead
# of sending real emails (see services/mailer.js → transport.dryrun).
MAIL_FROM=CelebrateBanner Dev <dev@example.com>
# POSTMARK_API_TOKEN=     # ← leave commented to keep emails in dev mode

RENDER_QUEUE_NAME=cb-renders-dev
RENDER_CONCURRENCY=1
RENDER_TIMEOUT_MS=120000
RENDER_ATTEMPTS=1                        # fail fast in dev

IMAGE_OPT_CONCURRENCY=2
IMAGE_OPT_DELAY_MS=1000                  # skip the upload wait

# Run the recovery worker once on demand: `RUN_ONCE=1 node workers/abandoned-checkout.worker.js`
RECOVERY_DELAY_HOURS=0
RECOVERY_DAILY_CAP=5

# No Sentry / alerts in dev — keep them out so we don't page on dev noise.
SENTRY_DSN=
ALERT_WEBHOOK_URL=

# Skip Postgres entirely (handy for UI development)
USE_MEMORY_PROJECT_STORE=0               # flip to 1 to bypass DB
