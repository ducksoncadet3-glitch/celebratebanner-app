# celebratebanner-api · PRODUCTION env template
#
# Copy to .env on the production box (or set as host secrets). Every var here
# is required unless explicitly marked optional. Run `node scripts/check-env.js`
# after loading to validate shape.
#
# Naming convention:
#   • UPPER_SNAKE_CASE
#   • Public keys prefixed PUBLIC_ (won't be redacted in logs)
#   • Anything secret unprefixed (will be redacted by services/logger.js)

# ── Core (REQUIRED) ─────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PUBLIC_SITE_URL=https://celebratebanner.com
API_PUBLIC_URL=https://api.celebratebanner.com

# ── Postgres (REQUIRED) ─────────────────────────────────────────────────────
# Use the LEAST-PRIVILEGE app_user role at runtime — NEVER the migrator role.
DATABASE_URL=postgres://app_user:STRONG_PASSWORD@HOST.example.com:5432/celebratebanner?sslmode=require
PG_SSL=require
PG_POOL_SIZE=10

# ── Redis (REQUIRED) ────────────────────────────────────────────────────────
# Must be rediss:// (TLS) in production.
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

# ── Stripe (REQUIRED) ───────────────────────────────────────────────────────
# Production uses sk_live_… and whsec_… for the LIVE webhook endpoint.
# Test-mode keys are explicitly rejected by scripts/check-env.js in production.
STRIPE_SECRET_KEY=sk_live_REPLACE
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# ── AWS S3 (REQUIRED) ───────────────────────────────────────────────────────
# IAM user has s3:PutObject / GetObject / DeleteObject on the bucket ONLY.
# Never use root keys.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA_REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
S3_BUCKET=celebratebanner-uploads-prod
S3_CDN_BASE=https://cdn.celebratebanner.com
S3_UPLOAD_TTL_SECONDS=600
S3_DOWNLOAD_TTL_SECONDS=604800

# ── Download tokens (REQUIRED) ──────────────────────────────────────────────
# Generate fresh: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# ROTATING this invalidates EVERY outstanding download link.
DOWNLOAD_TOKEN_SECRET=REPLACE_32_RANDOM_BYTES_BASE64URL
DOWNLOAD_TOKEN_TTL_DAYS=7
DOWNLOAD_TOKEN_MAX_USES=100

# ── Admin auth (REQUIRED) ───────────────────────────────────────────────────
# Same entropy requirement as DOWNLOAD_TOKEN_SECRET. Rotating logs out every admin.
ADMIN_JWT_SECRET=REPLACE_32_RANDOM_BYTES_BASE64URL
ADMIN_SESSION_TTL_HOURS=8
ADMIN_COOKIE_NAME=cb_admin
ADMIN_COOKIE_DOMAIN=.celebratebanner.com

# ── Mailer (REQUIRED) ───────────────────────────────────────────────────────
MAIL_FROM=CelebrateBanner <info@celebratebanner.com>
POSTMARK_API_TOKEN=REPLACE
POSTMARK_STREAM=outbound

# ── Render worker tuning (REQUIRED) ─────────────────────────────────────────
RENDER_QUEUE_NAME=cb-renders
RENDER_CONCURRENCY=2
RENDER_TIMEOUT_MS=300000
RENDER_ATTEMPTS=3

# ── Image optimizer ─────────────────────────────────────────────────────────
IMAGE_OPT_CONCURRENCY=4
IMAGE_OPT_DELAY_MS=8000

# ── Abandoned-checkout recovery ─────────────────────────────────────────────
RECOVERY_DELAY_HOURS=4
RECOVERY_INTERVAL_MS=900000
RECOVERY_DAILY_CAP=500

# ── Video slideshow (OPTIONAL — only required if you offer the +$19 upsell) ─
SLIDESHOW_FPS=30
SLIDESHOW_BITRATE=6M
SLIDESHOW_DEFAULT_AUDIO_URL=

# ── Observability (RECOMMENDED) ─────────────────────────────────────────────
SENTRY_DSN=https://PUBLIC_KEY@oXXXX.ingest.sentry.io/PROJECT
SENTRY_TRACES_SAMPLE_RATE=0.1
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE
ALERT_DEDUPE_TTL_SECONDS=300

# ── Backups ─────────────────────────────────────────────────────────────────
BACKUP_S3_BUCKET=celebratebanner-backups
BACKUP_RETENTION_DAYS=30
