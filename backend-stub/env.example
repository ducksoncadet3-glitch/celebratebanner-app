# celebratebanner-api server env — NEVER ship these to the browser.

# Stripe (Server) — secret key & webhook signing secret
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Public site URL — used to build success / cancel redirects
PUBLIC_SITE_URL=https://celebratebanner.com

# CelebrateBanner API (this server) — used in signed-URL generation
API_PUBLIC_URL=https://api.celebratebanner.com

# Optional: shared secret the frontend Next.js server uses for internal calls
API_SHARED_SECRET=replace_me_with_long_random_string

# Optional: legacy payment link kept temporarily for migration
LEGACY_STRIPE_PAYMENT_LINK=https://buy.stripe.com/7sY8wHeEUb9n27KgxR83C00

# Mailer (transactional)
MAIL_FROM="CelebrateBanner <info@celebratebanner.com>"
POSTMARK_API_TOKEN=replace_me
