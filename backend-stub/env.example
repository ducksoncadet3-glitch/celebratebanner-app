# celebratebanner-api production env — NEVER commit a filled-in copy.

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
API_PUBLIC_URL=https://api.celebratebanner.com
PUBLIC_SITE_URL=https://celebratebanner.com

# ── Postgres ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/celebratebanner
PG_POOL_SIZE=10
PG_SSL=require

# ── Redis (BullMQ + rate limiter) ───────────────────────────────────────────
REDIS_URL=rediss://default:pass@host:6379

# ── Render worker ───────────────────────────────────────────────────────────
RENDER_QUEUE_NAME=cb-renders
RENDER_CONCURRENCY=2
RENDER_TIMEOUT_MS=300000
RENDER_ATTEMPTS=3

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
LEGACY_STRIPE_PAYMENT_LINK=https://buy.stripe.com/7sY8wHeEUb9n27KgxR83C00

# ── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me
S3_BUCKET=celebratebanner-uploads-prod
S3_CDN_BASE=https://cdn.celebratebanner.com
S3_UPLOAD_TTL_SECONDS=600
S3_DOWNLOAD_TTL_SECONDS=604800

# ── Download tokens ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
DOWNLOAD_TOKEN_SECRET=replace_me_with_32_random_bytes
DOWNLOAD_TOKEN_TTL_DAYS=7
DOWNLOAD_TOKEN_MAX_USES=100

# ── Mailer ──────────────────────────────────────────────────────────────────
MAIL_FROM="CelebrateBanner <info@celebratebanner.com>"
POSTMARK_API_TOKEN=replace_me

# ── Video slideshow (optional) ──────────────────────────────────────────────
SLIDESHOW_FPS=30
SLIDESHOW_BITRATE=6M
SLIDESHOW_DEFAULT_AUDIO_URL=

# ── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Image optimizer ─────────────────────────────────────────────────────────
IMAGE_OPT_CONCURRENCY=4
IMAGE_OPT_DELAY_MS=8000

# ── Abandoned-checkout recovery worker ──────────────────────────────────────
RECOVERY_DELAY_HOURS=4
RECOVERY_INTERVAL_MS=900000
RECOVERY_DAILY_CAP=500

# ── Local dev override ──────────────────────────────────────────────────────
# Set to 1 to use an in-memory project store instead of Postgres (no DB needed).
USE_MEMORY_PROJECT_STORE=0
