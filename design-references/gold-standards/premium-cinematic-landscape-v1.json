  },
  "zIndex": { "background": 0, "particles": 5, "vignette": 8, "collage": 30, "decorationsBackground": 42, "hero": 40, "text": 60, "decorationsTitle": 55, "decorationsTopright": 58, "footer": 70 },
  "spacingRules": {
    "margins": "Title block anchored to left margin ~0.02–0.035; footer band spans full width; collage hugs left/right edges; hero centered.",
    "heroToNameOverlap": "Script name sits over the lower hero (y≈0.715); keepsake below."
  }
