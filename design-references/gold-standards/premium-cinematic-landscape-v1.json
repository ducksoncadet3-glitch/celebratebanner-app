  "decorationSlots": {
    "note": "The generic renderer draws product-supplied decorations in these phases and z-order. Each product adapter provides the actual decoration renderers + positions.",
    "phases": [
      { "phase": "background", "z": 42, "drawnAfter": "collage", "drawnBefore": "hero" },
      { "phase": "title",      "z": 55, "anchoredTo": "year" },
      { "phase": "topright",   "z": 58, "anchoredTo": "topQuote" }
