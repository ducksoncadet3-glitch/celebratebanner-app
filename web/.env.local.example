# /web (Next.js frontend) · LOCAL DEV env template
#
# Copy to .env.local. Next.js auto-loads .env.local in `npm run dev`.

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Use a pk_test_ from your Stripe test account.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_TEST_KEY
NEXT_PUBLIC_LEGACY_STRIPE_LINK=

API_INTERNAL_BASE_URL=http://localhost:4000
API_SHARED_SECRET=
