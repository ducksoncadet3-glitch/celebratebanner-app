# /web (Next.js frontend) · PRODUCTION env template
#
# Only NEXT_PUBLIC_* vars are shipped to the browser. Everything else is
# server-only (Server Components, Route Handlers).

# ── Public (in the browser bundle) ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://celebratebanner.com
NEXT_PUBLIC_API_BASE_URL=https://api.celebratebanner.com
# pk_live_… for production. Never put a secret key here.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE
# Legacy fallback (only used when our API returns 5xx). Leave blank to disable
# the fallback entirely once we're confident in the API.
NEXT_PUBLIC_LEGACY_STRIPE_LINK=

# ── Server-only (Route Handlers / Server Components) ───────────────────────
# Used by the autosave PATCH proxy to talk to the API. Same URL as the public
# one unless you're running the API on a private VPC URL only the Next runtime
# can reach.
API_INTERNAL_BASE_URL=https://api.celebratebanner.com
# Optional shared secret the API trusts as `x-internal-secret` header.
# Set this if you front the API with WAF rules that block requests without it.
API_SHARED_SECRET=
