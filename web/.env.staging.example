# /web (Next.js frontend) · STAGING env template

NEXT_PUBLIC_SITE_URL=https://staging.celebratebanner.com
NEXT_PUBLIC_API_BASE_URL=https://api.staging.celebratebanner.com
# pk_test_… on staging. Match the same Stripe account as the staging API.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE
# Force the legacy fallback off in staging — we never want to redirect staging
# traffic to the live payment link.
NEXT_PUBLIC_LEGACY_STRIPE_LINK=

API_INTERNAL_BASE_URL=https://api.staging.celebratebanner.com
API_SHARED_SECRET=
