# ─── Public (safe to ship to the browser) ─────────────────────────────────
# Where this Next app is hosted. Used for canonical URLs + Stripe redirects.
NEXT_PUBLIC_SITE_URL=https://celebratebanner.com

# Stripe publishable key (pk_live_... or pk_test_...) — public by design.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Public URL of the celebratebanner-api backend.
NEXT_PUBLIC_API_BASE_URL=https://api.celebratebanner.com

# Legacy Stripe payment link kept as fallback while migrating.
NEXT_PUBLIC_LEGACY_STRIPE_LINK=https://buy.stripe.com/7sY8wHeEUb9n27KgxR83C00

# ─── Server-only (NEVER ship to the browser) ──────────────────────────────
# Only set on the Vercel server runtime. Never prefix with NEXT_PUBLIC_.
API_INTERNAL_BASE_URL=https://api.celebratebanner.com
API_SHARED_SECRET=replace_me_with_long_random_string
